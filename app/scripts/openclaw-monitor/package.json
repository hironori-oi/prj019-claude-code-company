{
  "name": "@prj-019/openclaw-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Upstream change monitor for openclaw-runtime / claude-code / Anthropic Engineering blog. Outputs severity-classified notifications routed by DEC-019-035.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "check": "tsx src/check-upstream.ts",
    "report": "tsx src/check-upstream.ts --mode=report",
    "dispatch": "tsx src/check-upstream.ts --mode=dispatch",
    "cost-watcher": "tsx src/cost-watcher.ts",
    "cost-watcher:report": "tsx src/cost-watcher.ts --mode=report",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-xml-parser": "^4.4.0",
    "undici": "^6.19.0",
    "@supabase/supabase-js": "^2.46.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
