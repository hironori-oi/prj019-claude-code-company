{
  "_meta": {
    "rolloutPhase": "B (error)",
    "issue": "ARCH-01 (DEC-019-041)",
    "note": "web/ は Next.js 15 App Router 新規実装のため Phase B (strict 完全適用) を最初から適用。"
  },
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
