{
  "name": "@clawbridge/harness",
  "version": "0.1.0",
  "private": true,
  "description": "Clawbridge ハーネス制御層 (cost / kill-switch / HITL / circuit-breaker / usage-monitor)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cost-tracker": {
      "types": "./dist/cost-tracker.d.ts",
      "import": "./dist/cost-tracker.js"
    },
    "./kill-switch": {
      "types": "./dist/kill-switch.d.ts",
      "import": "./dist/kill-switch.js"
    },
    "./hitl-gate": {
      "types": "./dist/hitl-gate.d.ts",
      "import": "./dist/hitl-gate.js"
    },
    "./circuit-breaker": {
      "types": "./dist/circuit-breaker.d.ts",
      "import": "./dist/circuit-breaker.js"
    },
    "./usage-monitor": {
      "types": "./dist/usage-monitor.d.ts",
      "import": "./dist/usage-monitor.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawbridge/audit": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.10.0"
  }
}
