# =============================================================================
# PRJ-019 Clawbridge - Environment Variables Template (v2 / DEC-019-053)
# (DEC-019-048 = 1Password CLI 採択 / DEC-019-049 = Slack 新規 workspace
#  / DEC-019-053 = 真の secret のみ Vault 登録、それ以外は平文で分離)
#
# !! 構造 !!
#   本ファイルは 4 ブロック構造で運用する:
#     [Block 1] True secrets (Vault 登録必須)   — 9 fields / 4 items
#     [Block 2] Public config (browser exposed) — 2 fields (NEXT_PUBLIC_*)
#     [Block 3] Local paths / version pins      — 4 fields (path / version)
#     [Block 4] Constants / feature flags       — 16+ fields (定数)
#
#   合計: 9 fields op:// + 12 fields 平文 dummy + 既存定数
#   Vault 登録対象は **9 fields** のみ (DEC-019-053、Owner 即決 2026-05-04)。
#
# !! 重要ルール !!
#   - Block 1 のみ 1Password Vault 必須。`op://prj019/<service>/<field>` 形式維持。
#   - Block 2/3/4 は dummy 値を平文記載。実値は `.env.local` で上書き or
#     Vercel 環境変数で別管理 (NEXT_PUBLIC_* は Vercel project settings 推奨)。
#   - 推奨実行 path:
#       op signin
#       op run --env-file=.env.local -- pnpm dev      # Tier 1 解決込み
#       pnpm dev:noop                                  # Tier 2 のみ (op 未要求)
#   - 1Password CLI 未導入の環境でも `dev:noop` で localhost:3000 起動可能
#     (DEC-019-053 / Owner 5/4 検証済 = 公式 unblock path)。
#   - `service_role` 系キーは Web 層 (Next.js API route) でのみ参照、
#     subprocess (claude-bridge / openclaw-runtime) には絶対に渡さない
#     (DEC-019-033 §⑤ priviledge escalation 物理防止)。
#   - Slack workspace は PRJ-019 専用 `prj019-claude-code-company` を新規作成
#     (DEC-019-049)。HITL / monitor / drill の 3 channel を独立運用。
# =============================================================================


# =============================================================================
# [Block 1] True secrets (Vault 登録必須) — 9 fields / 4 items
# 変更時の Vault 影響: あり (Owner 操作 + rotation SOP 適用)
# =============================================================================

# ---------- Supabase (2 fields) ----------
# service_role は subprocess 漏洩禁止 (DEC-019-033 §⑤)、
# DB_URL は CLI migrate 用 (Web ランタイムからは参照しない)
SUPABASE_SERVICE_ROLE_KEY=op://prj019/supabase/service_role_key
SUPABASE_DB_URL=op://prj019/supabase/db_url

# ---------- Slack 3 webhook (DEC-019-049: 3 channel 独立運用) ----------
# workspace `prj019-claude-code-company` 内 3 channel:
#   #hitl     — HITL 11 種承認待ち通知 (低 severity)
#   #monitor  — 上流 changelog / 監査異常 (中 severity)
#   #drill    — BAN drill / kill switch / インシデント (高 severity)
SLACK_WEBHOOK_HITL=op://prj019/slack/webhook_hitl
SLACK_WEBHOOK_MONITOR=op://prj019/slack/webhook_monitor
SLACK_WEBHOOK_DRILL=op://prj019/slack/webhook_drill

# ---------- Notification (3 fields) ----------
# api_key は credential、emails は PII (Vault 集約で運用一元化)
RESEND_API_KEY=op://prj019/resend/api_key
OWNER_NOTIFY_EMAIL=op://prj019/notify/owner_email
DEV_NOTIFY_EMAIL=op://prj019/notify/dev_email

# ---------- GitHub PAT (1 field) ----------
# upstream monitor 用 read-only PAT (rate-limit 緩和、anonymous でも動く)
GITHUB_PAT_READ_ONLY=op://prj019/github/pat_read_only


# =============================================================================
# [Block 2] Public config (browser exposed) — 2 fields
# 変更時の Vault 影響: なし (browser に公開される前提、Vercel 環境変数で別管理推奨)
# RLS で行レベル保護、anon_key は公開キー (Supabase 標準想定)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://example-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.dummy.anon_key_replace_in_local


# =============================================================================
# [Block 3] Local paths / version pins — 4 fields
# 変更時の Vault 影響: なし (環境固有の path / version、`.env.local` で上書き)
# =============================================================================

# ---------- Tenant binding (UUID 識別子、定数扱い) ----------
CLAWBRIDGE_TENANT_ID=00000000-0000-0000-0000-000000000000
CLAWBRIDGE_OWNER_USER_ID=00000000-0000-0000-0000-000000000001

# ---------- Claude Code CLI (P-D 改) ----------
# 本人 OAuth に委譲するため API キーは原則 unset。
# CLI 起動時に subprocess 自身が auth を解決する。
CLAUDE_CODE_CLI_PATH=/usr/local/bin/claude
CLAUDE_CODE_PINNED_VERSION=2.0.0

# ---------- Open Claw OSS ----------
OPENCLAW_BINARY_PATH=/usr/local/bin/openclaw
OPENCLAW_PINNED_VERSION=0.1.0


# =============================================================================
# [Block 4] Constants / feature flags
# 変更時の Vault 影響: なし (定数・フラグ、リポジトリ正本で OK)
# =============================================================================

# ---------- Cost / Spend Cap (DEC-019-031) ----------
SPEND_CAP_MONTHLY_USD=300
SPEND_CAP_PROPOSAL_USD=20
SPEND_CAP_TASK_USD=2

# ---------- Anthropic API Spend Cap (DEC-019-050) ----------
# 二重防御 (Anthropic Console Hard $30 + アプリ層実装ガード)。
# 三段階閾値 = warn (80%) / auto_stop (95%) / hard_fail (100%) を ENV で override 可能。
# 順序整合 (warn < stop < cap) が崩れた場合は default に fallback する (budget-guard.ts)。
ANTHROPIC_MONTHLY_CAP_USD=30
ANTHROPIC_WARN_THRESHOLD=24
ANTHROPIC_STOP_THRESHOLD=28.5

# ---------- Slack channel labels (DEC-019-049) ----------
SLACK_CHANNEL_HITL=#hitl
SLACK_CHANNEL_MONITOR=#monitor
SLACK_CHANNEL_DRILL=#drill

# ---------- Vercel (deploy meta, optional) ----------
# Vercel が自動注入するメタ情報のため平文維持
VERCEL_ENV=
VERCEL_GIT_COMMIT_SHA=

# ---------- Casbin policy ----------
CASBIN_MODEL_PATH=./policies/casbin/model.conf
CASBIN_POLICY_PATH=./policies/casbin/policy.csv

# ---------- Feature flags (initial defaults, fail-closed) ----------
FEATURE_TOOLS_SEARCH=false
FEATURE_WEB_FETCH=false
FEATURE_FILE_WRITE=false
FEATURE_SHELL_EXEC=false

# ---------- Audit verify ----------
AUDIT_VERIFY_BATCH_SIZE=1000

# ---------- Timezone (JST 基準, DEC-019-033 §⑤ time category) ----------
TZ=Asia/Tokyo

# ---------- Node env ----------
NODE_ENV=development
