{
  "name": "@clawbridge/claude-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code CLI subprocess spawn 層 (P-D 改, 本人 OAuth)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:integration:live": "vitest run --enable-live integration/",
