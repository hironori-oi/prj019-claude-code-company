    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawbridge/harness": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.10.0"
  }
}
